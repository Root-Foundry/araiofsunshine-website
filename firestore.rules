rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Events collection
    match /events/{eventId} {
      // Anyone can read events (public calendar)
      allow read: if true;
      
      // Only authenticated admin users can create, update, or delete events
      allow create, update, delete: if request.auth != null;
    }
    
    // Sponsors collection
    match /sponsors/{sponsorId} {
      // Anyone can read sponsors (public display)
      allow read: if true;
      
      // Only authenticated admin users can create, update, or delete sponsors
      allow create, update, delete: if request.auth != null;
    }
  }
}
